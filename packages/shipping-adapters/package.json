{
  "name": "@eticart/shipping-adapters",
  "version": "0.6.0",
  "private": true,
  "description": "Kargo adaptörleri (manuel + Türkiye sağlayıcıları).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manual": {
      "types": "./dist/manual/index.d.ts",
      "default": "./dist/manual/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@eticart/config": "workspace:*"
  },
  "devDependencies": {
    "@eticart/eslint-config": "workspace:*",
    "@eticart/shared-types": "workspace:*",
    "@eticart/tsconfig": "workspace:*",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}