{
  "name": "@eticart/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Ortak UI bileşenleri — erişilebilir ve Türkçe yerelleştirilmiş. Faz 5'te genişletilecek.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "echo \"ui: Faz 5'te testler eklenecek\"",
    "build": "tsc",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eticart/eslint-config": "workspace:*",
    "@eticart/tsconfig": "workspace:*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
