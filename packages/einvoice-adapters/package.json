{
  "name": "@eticart/einvoice-adapters",
  "version": "0.1.0",
  "private": true,
  "description": "e-Fatura / e-Arşiv / e-İrsaliye adaptörleri (NES, Logo, Mikro, Foriba).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./common": {
      "types": "./dist/common/index.d.ts",
      "default": "./dist/common/index.js"
    },
    "./nes": {
      "types": "./dist/nes/index.d.ts",
      "default": "./dist/nes/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "echo 'lint: Faz 11'",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@eticart/config": "workspace:*",
    "@eticart/shared-types": "workspace:*",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@eticart/eslint-config": "workspace:*",
    "@eticart/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}