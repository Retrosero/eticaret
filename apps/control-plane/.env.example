# control-plane ortam değişkenleri şablonu
# Üretimde zorunlu alanlar: NODE_ENV, DATABASE_URL, JWT_SECRET, ALLOWED_CORS

NODE_ENV=development
LOG_LEVEL=info
APP_VERSION=0.1.0

# Kontrol düzlemi
CONTROL_PLANE_PORT=4000
CONTROL_PLANE_GLOBAL_PREFIX=api/v1

# Veritabanı (pg_control — ortak kontrol şeması)
DATABASE_URL=postgresql://eticart:eticart@localhost:5432/eticart_control
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (cache + throttle)
REDIS_URL=redis://localhost:6379

# CORS allowlist (virgülle ayrılmış; * yok)
CONTROL_PLANE_CORS=http://localhost:3001,http://localhost:3002

# Rate limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Request body limiti (varsayılan 1mb)
REQUEST_BODY_LIMIT=1mb

# JWT (Faz 3)
JWT_SECRET=replace-with-strong-secret-32-chars-min
JWT_EXPIRES_IN=3600

# OpenAPI
API_DOCS_ENABLED=true
API_DOCS_PATH=docs

# Sentry (opsiyonel)
SENTRY_DSN=
