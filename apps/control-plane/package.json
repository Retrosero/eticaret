{
  "name": "@eticart/control-plane",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS kontrol düzlemi — NestJS (Faz 1 iskeleti)",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "node ./scripts/migrate.js",
    "seed": "node ./scripts/seed.js",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@eticart/auth": "workspace:*",
    "@eticart/config": "workspace:*",
    "@eticart/observability": "workspace:*",
    "@eticart/notification-adapters": "workspace:*",
    "@eticart/region-router": "workspace:*",
    "@eticart/shared-types": "workspace:*",
    "@eticart/tenant-context": "workspace:*",
    "@eticart/validation": "workspace:*",
    "@nestjs/common": "^10.4.6",
    "@nestjs/core": "^10.4.6",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/throttler": "^6.2.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eticart/eslint-config": "workspace:*",
    "@eticart/tsconfig": "workspace:*",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.15.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
