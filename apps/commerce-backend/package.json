{
  "name": "@eticart/commerce-backend",
  "version": "0.1.0",
  "private": true,
  "description": "E-ticaret çekirdeği (Faz 4): ürün/PIM/kategori/marka/stok/fiyat modülleri. Medusa'ya geçiş Faz 5+ sonrası planlanıyor.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run test/",
    "test:unit": "vitest run src/",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset",
    "migrate:test": "DATABASE_URL=postgresql://test:test@localhost:5433/eticart_test prisma migrate deploy",
    "seed": "tsx ./scripts/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@eticart/auth": "workspace:*",
    "@eticart/config": "workspace:*",
    "@eticart/einvoice-adapters": "workspace:*",
    "@eticart/notification-adapters": "workspace:*",
    "@eticart/observability": "workspace:*",
    "@eticart/payment-adapters": "workspace:*",
    "@eticart/shared-types": "workspace:*",
    "@eticart/shipping-adapters": "workspace:*",
    "@eticart/storage-adapter": "workspace:*",
    "@eticart/validation": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.15.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}