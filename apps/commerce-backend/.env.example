# commerce-backend (Medusa) — ortam değişkenleri şablonu
# Üretimde zorunlu: NODE_ENV, DATABASE_URL, REDIS_URL, JWT_SECRET, COOKIE_SECRET

NODE_ENV=development
LOG_LEVEL=info
APP_VERSION=0.1.0

# Medusa (e-ticaret çekirdeği)
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_URL=http://localhost:7001
STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:7001,http://localhost:3001
AUTH_CORS=http://localhost:7001,http://localhost:8000,http://localhost:3000

# Tek bir Postgre — pg_app + pg_control aynı sunucuda
DATABASE_URL=postgresql://eticart:eticart@localhost:5432/eticart_app

# Redis
REDIS_URL=redis://localhost:6379

# JWT ve oturum cookie
JWT_SECRET=replace-with-strong-secret-at-least-32-chars
COOKIE_SECRET=replace-with-strong-secret-at-least-32-chars

# Tenant bağlamı (Faz 2 ile kullanılacak — hangi şemaya bağlanacağı)
MEDUSA_TENANT_RESOLVER=host

# Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=eticart-uploads

# Ödeme sağlayıcıları (iyzico)
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_TEST_MODE=true

# Ödeme sağlayıcıları (PayTR)
PAYTR_MERCHANT_ID=your-merchant-id
PAYTR_MERCHANT_KEY=your-merchant-key
PAYTR_MERCHANT_SALT=your-merchant-salt
PAYTR_TEST_MODE=true

# Ödeme sağlayıcıları (Param)
PARAM_CLIENT_CODE=your-client-code
PARAM_CLIENT_USERNAME=your-username
PARAM_CLIENT_PASSWORD=your-password
PARAM_TEST_MODE=true

# Kargo sağlayıcıları (Yurtiçi)
YURTICI_API_USER=your-api-user
YURTICI_API_PASSWORD=your-api-password
YURTICI_CUSTOMER_CODE=your-customer-code

# Kargo sağlayıcıları (MNG)
MNG_API_KEY=your-api-key
MNG_PASSWORD=your-password
MNG_CUSTOMER_CODE=your-customer-code

# =============================================================
# e-Fatura / e-Arşiv adaptörü (NES — nes.com.tr)
# =============================================================
# NES GİB onaylı özel entegratördür (nes.com.tr).
# Geliştirici hesabı: developer.nes.com.tr
# Üretim:  https://api.nes.com.tr
# Sandbox: https://api-test.nes.com.tr
#
# OAuth2 client_credentials akışı ile Bearer token alınır.
NES_API_KEY=your-nes-client-id
NES_API_SECRET=your-nes-client-secret
NES_CUSTOMER_ID=your-nes-mukellef-kodu
NES_TEST_MODE=true
# Opsiyonel override:
# NES_BASE_URL=

# Satıcı (firma) bilgileri — e-fatura/fatura üzerinde görünür
SELLER_TAX_ID=your-company-tax-id
SELLER_TAX_OFFICE=your-tax-office
SELLER_LEGAL_NAME=Your Company A.S.
SELLER_ADDRESS_STREET=Merkez Mah. No:1
SELLER_ADDRESS_CITY=Istanbul
SELLER_ADDRESS_COUNTRY=TR
SELLER_EMAIL=billing@yourcompany.com
SELLER_PHONE=+902120000000

# iyzico webhook secret (HTTP HMAC doğrulama)
IYZICO_WEBHOOK_SECRET=your-webhook-secret
