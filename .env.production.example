# EtiCart — Production Environment Variables
#
# Coolify'ta bu değişkenleri Secrets olarak tanımlayın.
# Hiçbir secret'ı git'e commit etmeyin!
#
# Coolify: Project → Service → Environment Variables

# =============================================================
# ZORUNLU — Veritabanı
# =============================================================
POSTGRES_PASSWORD=GENERATE_STRONG_PASSWORD_HERE
POSTGRES_PORT=5432
POSTGRES_USER=eticart

# =============================================================
# ZORUNLU — JWT / Cookie secrets
# =============================================================
# 32+ karakter, rastgele. Üretmek için:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=GENERATE_RANDOM_48_BYTE_BASE64_HERE
COOKIE_SECRET=GENERATE_DIFFERENT_RANDOM_48_BYTE_BASE64_HERE

# =============================================================
# ZORUNLU — Site URL'leri (CORS)
# =============================================================
NEXT_PUBLIC_SITE_URL=https://eticart.com.tr
NEXT_PUBLIC_API_URL=https://api.eticart.com.tr
STORE_CORS=https://eticart.com.tr
ADMIN_CORS=https://admin.eticart.com.tr
AUTH_CORS=https://admin.eticart.com.tr,https://eticart.com.tr

# =============================================================
# OPSİYONEL — Loglama
# =============================================================
LOG_LEVEL=info
APP_VERSION=0.9.0

# =============================================================
# OPSİYONEL — Port yayınlama (Coolify otomatik yönetir)
# =============================================================
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=9000
STOREFRONT_PORT=3000
ADMIN_PORT=3001

# =============================================================
# OPSİYONEL — Ödeme Sağlayıcıları
# =============================================================
# iyzico (production)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_TEST_MODE=false
IYZICO_WEBHOOK_SECRET=

# PayTR
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=false

# Param
PARAM_CLIENT_CODE=
PARAM_CLIENT_USERNAME=
PARAM_CLIENT_PASSWORD=
PARAM_TEST_MODE=false

# =============================================================
# OPSİYONEL — Kargo Sağlayıcıları
# =============================================================
YURTICI_API_USER=
YURTICI_API_PASSWORD=
YURTICI_CUSTOMER_CODE=

MNG_API_KEY=
MNG_PASSWORD=
MNG_CUSTOMER_CODE=

# =============================================================
# OPSİYONEL — NES e-Fatura
# =============================================================
NES_API_KEY=
NES_API_SECRET=
NES_CUSTOMER_ID=
NES_TEST_MODE=false

# =============================================================
# ZORUNLU — Satıcı (firma) bilgileri
# =============================================================
SELLER_TAX_ID=1234567890
SELLER_TAX_OFFICE=Beyoğlu
SELLER_LEGAL_NAME=Your Company A.S.
SELLER_ADDRESS_STREET=Merkez Mah. No:1
SELLER_ADDRESS_CITY=Istanbul
SELLER_EMAIL=billing@yourcompany.com
SELLER_PHONE=+902120000000

# =============================================================
# OPSİYONEL — Storage (S3/R2/MinIO)
# =============================================================
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=eticart-uploads

# =============================================================
# OPSİYONEL — Email (SMTP/Resend)
# =============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=noreply@eticart.com.tr
SMTP_FROM_NAME=EtiCart

# Resend.com (alternatif HTTP API — opsiyonel)
RESEND_API_KEY=

# Genel (SMTP ve Resend için)
MAIL_FROM=noreply@eticart.com.tr
MAIL_FROM_NAME=EtiCart

# Şablonlardaki link üretimi için
STOREFRONT_URL=https://eticart.com.tr
ADMIN_URL=https://admin.eticart.com.tr

# =============================================================
# Storage (S3/R2) — multi-tenant dosya depolama
# =============================================================
# S3 veya R2 için doldur; boş bırakılırsa InMemory (test/dev) kullanılır.

# AWS S3 örneği:
# S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# S3_REGION=eu-central-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=eticart-prod
# S3_FORCE_PATH_STYLE=false

# Cloudflare R2 örneği (KVKK uyumlu, AB bölgesi):
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=eticart-prod-r2
S3_PUBLIC_BASE_URL=https://media.eticart.com.tr

# Geliştirme için yerel disk (MinIO veya local fs):
# LOCAL_STORAGE_DIR=/var/lib/eticart/storage
# LOCAL_STORAGE_PUBLIC_URL=http://localhost:9000/static
# LOCAL_STORAGE_SIGNING_SECRET=change-me-min-16-chars

# =============================================================
# OPSİYONEL — Monitoring (Sentry vb.)
# =============================================================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=