{
  "name": "@eticart/infra-scripts",
  "version": "0.1.0",
  "private": true,
  "description": "Migration, seed ve tenant provision script'leri. Faz 1 iskeleti.",
  "type": "module",
  "scripts": {
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "provision": "tsx src/provision-tenant.ts",
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
