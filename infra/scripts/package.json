    "build": "tsc",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@eticart/observability": "workspace:*",
    "@eticart/validation": "workspace:*",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eticart/eslint-config": "workspace:*",
    "@eticart/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
