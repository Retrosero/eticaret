# =====================================================================
# Kök ortam değişkenleri şablonu — Türkçe e-ticaret SaaS platformu
# =====================================================================
# Bu şablonu `.env` olarak kopyalayın (`.env` git'te izlenmez).
# Asla gerçek secret değerlerini buraya işlemeyin.
# =====================================================================

# ----- Genel -----
NODE_ENV=development
LOG_LEVEL=info
APP_VERSION=0.1.0

# ----- Kontrol düzlemi veritabanı (NestJS) -----
# Hem control hem app için tek bir Postgres kullanılır; tenant şemaları ayrıdır.
DATABASE_URL=postgresql://eticart:eticart@localhost:5432/eticart_control
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- Medusa (e-ticaret çekirdeği) -----
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_URL=http://localhost:7001
MEDUSA_STORE_CORS=http://localhost:8000,http://localhost:3000
MEDUSA_ADMIN_CORS=http://localhost:7001,http://localhost:3001
MEDUSA_SECRET=replace-me-with-strong-secret-at-least-32-chars
MEDUSA_JWT_SECRET=replace-me-with-jwt-secret-32-chars
MEDUSA_COOKIE_SECRET=replace-me-with-cookie-secret-32-chars

# ----- Kontrol Düzlemi (NestJS) -----
CONTROL_PLANE_PORT=4000
CONTROL_PLANE_CORS=http://localhost:3001,http://localhost:3002
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
REQUEST_BODY_LIMIT=1mb

# ----- Storefront -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_API=http://localhost:9000

# ----- Tenant Admin -----
NEXT_PUBLIC_TENANT_ADMIN_URL=http://localhost:3001

# ----- Süper Admin -----
NEXT_PUBLIC_SUPER_ADMIN_URL=http://localhost:3002

# ----- Storage (MinIO — R2 simülasyonu) -----
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=eticart-uploads

# ----- E-posta (MailHog — dev) -----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="EtiCart <noreply@example.com>"

# ----- Telemetri (opsiyonel) -----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
